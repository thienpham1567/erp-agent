{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erp-agent.local/profile.schema.json",
  "title": "erp-agent project profile",
  "type": "object",
  "required": ["frameworkVersion", "project", "paths"],
  "properties": {
    "frameworkVersion": {
      "type": "string",
      "description": "Version of the erp-agent framework this profile was generated with."
    },
    "project": {
      "type": "object",
      "required": ["name", "stack"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "stack": {
          "type": "object",
          "required": ["nextVersion", "stateLib", "i18nLib", "uiPackage"],
          "properties": {
            "nextVersion": { "type": "string" },
            "stateLib": { "type": "string", "enum": ["rtk-query", "react-query", "swr", "other"] },
            "i18nLib": { "type": "string" },
            "i18nLocalesPath": { "type": "string", "description": "Relative path to i18n locale files, e.g. shared/i18n/locales." },
            "uiPackage": { "type": "string", "description": "Import alias for the shared UI package, e.g. @shared/ui." }
          }
        },
        "apps": {
          "type": "array",
          "description": "Workspace apps in this repo (monorepos only). Single-app projects may omit this or list one entry.",
          "items": {
            "type": "object",
            "required": ["name", "path"],
            "properties": {
              "name": { "type": "string", "minLength": 1, "description": "e.g. admin, client." },
              "path": { "type": "string", "minLength": 1, "description": "Relative path, e.g. apps/admin." },
              "authCookie": { "type": "string" },
              "apiBase": { "type": "string" },
              "forbiddenUx": { "type": "string", "description": "page | toast | custom" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    "paths": {
      "type": "object",
      "required": ["frameworkRoot", "profileRoot", "extractRoot"],
      "properties": {
        "frameworkRoot": { "type": "string", "description": "Absolute path to ~/.erp-agent/." },
        "profileRoot": { "type": "string", "description": "Path (relative to project root) to .agent/." },
        "extractRoot": { "type": "string", "description": "Path for Figma/Confluence extraction artifacts." },
        "sharedRoot": { "type": "string", "description": "Path to shared workspace packages (e.g. shared/)." }
      }
    },
    "scripts": {
      "type": "object",
      "description": "Project composite scripts the agent should prefer over raw tooling.",
      "properties": {
        "verify": { "type": "string", "description": "Command that runs the full verify gate, e.g. pnpm run verify." },
        "typecheck": { "type": "string" },
        "lint": { "type": "string" },
        "test": { "type": "string" }
      },
      "additionalProperties": true
    },
    "mcp": {
      "type": "object",
      "properties": {
        "figmaEnv": { "type": "string" },
        "confluenceEnv": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
