#!/usr/bin/env bash
set -euo pipefail

resolve_path() {
  local p="$1"
  if command -v readlink >/dev/null 2>&1 && readlink -f "$p" >/dev/null 2>&1; then
    readlink -f "$p"
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$p"
  else
    (cd "$(dirname "$p")" && printf '%s/%s\n' "$(pwd -P)" "$(basename "$p")")
  fi
}

FRAMEWORK_ROOT="$(cd "$(dirname "$(resolve_path "${BASH_SOURCE[0]}")")/.." && pwd)"
VERSION="0.1.0"

usage() {
  cat <<EOF
erp-agent ${VERSION}
Usage: erp-agent <command>
Commands:
  init      Scaffold .agent/ and AGENTS.md into the current project
  update    git pull the framework (drift detection not implemented)
  doctor    Validate .agent/profile.json against the schema
  version   Print framework version
EOF
}

cmd_version() { echo "erp-agent ${VERSION}"; }

cmd_update() {
  echo "Updating framework at ${FRAMEWORK_ROOT} ..."
  git -C "${FRAMEWORK_ROOT}" pull --ff-only
  echo "Note: template drift is not computed automatically."
  echo "To compare, run 'erp-agent init' in a fresh scratch dir and diff against your .agent/."
}

ask() {
  local prompt="$1" default="${2:-}" reply
  if [[ -n "${default}" ]]; then
    read -r -p "${prompt} [${default}]: " reply
    printf '%s' "${reply:-${default}}"
  else
    read -r -p "${prompt}: " reply
    printf '%s' "${reply}"
  fi
}

json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

interpolate() {
  local src="$1" dst="$2" mode="$3"
  shift 3
  local content
  content="$(cat "${src}")"
  local pair key val
  for pair in "$@"; do
    case "${pair}" in
      --*=*)
        key="${pair%%=*}"; key="${key#--}"
        val="${pair#*=}"
        if [[ "${mode}" == "json" && "${key}" != "APPS_JSON" ]]; then
          val="$(json_escape "${val}")"
        fi
        content="${content//\{\{${key}\}\}/${val}}"
        ;;
    esac
  done
  mkdir -p "$(dirname "${dst}")"
  printf '%s\n' "${content}" > "${dst}"
}

build_apps_json() {
  local csv="$1"
  if [[ -z "${csv}" ]]; then
    printf '[]'
    return
  fi
  local entry name path first=1 out='['
  IFS=',' read -ra entries <<< "${csv}"
  for entry in "${entries[@]}"; do
    entry="${entry# }"; entry="${entry% }"
    [[ -z "${entry}" ]] && continue
    name="${entry%%:*}"
    path="${entry#*:}"
    [[ "${name}" == "${entry}" ]] && path="${name}"
    name="$(json_escape "${name}")"
    path="$(json_escape "${path}")"
    if (( first )); then first=0; else out+=","; fi
    out+="{\"name\":\"${name}\",\"path\":\"${path}\"}"
  done
  out+=']'
  printf '%s' "${out}"
}

append_gitignore() {
  local dir="$1"
  local file="${dir}/.gitignore"
  if [[ ! -f "${file}" ]] || ! grep -q '^_extract/\?$' "${file}"; then
    printf '\n# erp-agent extraction artifacts\n_extract/\n' >> "${file}"
  fi
}

cmd_init() {
  local target="${PWD}"
  if [[ -d "${target}/.agent" ]]; then
    echo "error: .agent/ already exists at ${target}. Aborting." >&2
    exit 1
  fi
  if [[ -f "${target}/AGENTS.md" ]]; then
    echo "error: AGENTS.md already exists at ${target}. Remove or rename it, then re-run init." >&2
    exit 1
  fi

  echo "Initializing erp-agent profile at ${target}"
  local project_name next_version state_lib i18n_lib i18n_locales_path ui_package shared_root verify_script apps_csv apps_json
  project_name="$(ask "Project name" "$(basename "${target}")")"
  next_version="$(ask "Next.js version" "14")"
  state_lib="$(ask "State library (rtk-query|react-query|swr|other)" "rtk-query")"
  i18n_lib="$(ask "i18n library" "react-i18next")"
  i18n_locales_path="$(ask "i18n locales path (relative to repo root)" "shared/i18n/locales")"
  ui_package="$(ask "Shared UI package alias" "@shared/ui")"
  shared_root="$(ask "Shared packages root (relative to repo root; blank if none)" "shared")"
  verify_script="$(ask "Verify script to run at VF (blank to use tsc + eslint)" "")"
  apps_csv="$(ask "Workspace apps as comma-separated name:path (blank = single app)" "")"

  case "${state_lib}" in
    rtk-query|react-query|swr|other) ;;
    *) echo "error: stateLib must be one of: rtk-query|react-query|swr|other" >&2; exit 1 ;;
  esac
  if [[ -z "${project_name}" ]]; then
    echo "error: project name cannot be empty" >&2; exit 1
  fi

  apps_json="$(build_apps_json "${apps_csv}")"

  local src="${FRAMEWORK_ROOT}/templates"
  local dst="${target}"

  local f rel out mode
  while IFS= read -r -d '' f; do
    rel="${f#${src}/}"
    out="${dst}/${rel%.tmpl}"
    if [[ "${out}" == *.json ]]; then mode="json"; else mode="raw"; fi
    interpolate "${f}" "${out}" "${mode}" \
      --PROJECT_NAME="${project_name}" \
      --NEXT_VERSION="${next_version}" \
      --STATE_LIB="${state_lib}" \
      --I18N_LIB="${i18n_lib}" \
      --I18N_LOCALES_PATH="${i18n_locales_path}" \
      --UI_PACKAGE="${ui_package}" \
      --SHARED_ROOT="${shared_root}" \
      --VERIFY_SCRIPT="${verify_script}" \
      --APPS_JSON="${apps_json}" \
      --FRAMEWORK_ROOT="${FRAMEWORK_ROOT}" \
      --FRAMEWORK_VERSION="${VERSION}"
  done < <(find "${src}" -type f -print0)

  append_gitignore "${dst}"

  local leftover
  leftover="$(grep -REho '\{\{[A-Z_]+\}\}' "${dst}/.agent" "${dst}/AGENTS.md" 2>/dev/null | sort -u || true)"
  if [[ -n "${leftover}" ]]; then
    echo "warning: un-interpolated placeholders remain:" >&2
    echo "${leftover}" >&2
  fi

  echo "Profile written to ${target}/.agent/"
  echo "AGENTS.md written to ${target}/AGENTS.md"
  echo "Next: edit .agent/context/*.md to reflect your project."
}

cmd_doctor() {
  local profile="${PWD}/.agent/profile.json"
  if [[ ! -f "${profile}" ]]; then
    echo "error: no .agent/profile.json in ${PWD}" >&2
    exit 1
  fi
  ERP_PROFILE="${profile}" \
  ERP_SCHEMA="${FRAMEWORK_ROOT}/schema/profile.schema.json" \
  node -e '
    const fs = require("fs");
    const profile = JSON.parse(fs.readFileSync(process.env.ERP_PROFILE, "utf8"));
    const schema = JSON.parse(fs.readFileSync(process.env.ERP_SCHEMA, "utf8"));
    const errors = [];
    function walk(node, subSchema, path) {
      if (!subSchema) return;
      if (subSchema.type === "object") {
        if (typeof node !== "object" || node === null || Array.isArray(node)) {
          errors.push(path + ": expected object");
          return;
        }
        for (const key of subSchema.required || []) {
          if (!(key in node)) errors.push((path || "(root)") + ": missing required " + key);
        }
        const props = subSchema.properties || {};
        for (const [k, v] of Object.entries(node)) {
          if (props[k]) walk(v, props[k], path ? path + "." + k : k);
          else if (subSchema.additionalProperties === false) {
            errors.push((path || "(root)") + ": unexpected property " + k);
          }
        }
      } else if (subSchema.type === "string") {
        if (typeof node !== "string") { errors.push(path + ": expected string"); return; }
        if (subSchema.minLength && node.length < subSchema.minLength) {
          errors.push(path + ": shorter than minLength " + subSchema.minLength);
        }
        if (subSchema.enum && !subSchema.enum.includes(node)) {
          errors.push(path + ": not in enum " + JSON.stringify(subSchema.enum));
        }
      }
    }
    walk(profile, schema, "");
    if (errors.length) {
      for (const e of errors) console.error(e);
      process.exit(1);
    }
    console.log("profile.json: ok");
  '
}

main() {
  local cmd="${1:-}"
  case "${cmd}" in
    init) cmd_init ;;
    update) cmd_update ;;
    doctor) cmd_doctor ;;
    version|--version|-v) cmd_version ;;
    ""|help|--help|-h) usage ;;
    *) echo "unknown command: ${cmd}"; usage; exit 1 ;;
  esac
}

main "$@"
